.page {
  min-height: 100vh;
  padding: 24rpx;
  background: #f5f7fb;
}

.tabs {
  display: flex;
  background: #ffffff;
  border-radius: 18rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 20rpx rgba(35, 48, 88, 0.06);
  margin-bottom: 20rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: #6b7280;
}

.tab.active {
  color: #2b4fdf;
  background: #eef2ff;
  font-weight: 600;
}

.card {
  padding: 20rpx;
  background: #ffffff;
  border-radius: 18rpx;
  box-shadow: 0 10rpx 26rpx rgba(35, 48, 88, 0.06);
  margin-bottom: 20rpx;
}

.input {
  height: 80rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  margin-bottom: 16rpx;
  background: #f8fafc;
}

.primary-btn {
  height: 72rpx;
  line-height: 72rpx;
  background: #2b4fdf;
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.row {
  padding: 16rpx;
  border-radius: 14rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(35, 48, 88, 0.05);
}

.row-title {
  font-size: 26rpx;
  color: #1f2a44;
}

.row-sub {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #6b7280;
}

.empty {
  text-align: center;
  color: #8b94a6;
  padding: 24rpx 0;
}
