/**index.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f7fb;
}
.scrollarea {
  flex: 1;
  overflow-y: hidden;
}

.container {
  padding: 24rpx;
}

.section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2a44;
  margin-bottom: 16rpx;
}

.toolbar {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 24rpx;
}

.primary-btn {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 28rpx;
  background: #2b4fdf;
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  padding: 24rpx;
  background: #ffffff;
  border-radius: 18rpx;
  box-shadow: 0 12rpx 30rpx rgba(35, 48, 88, 0.08);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2a44;
}

.card-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #5b6478;
}

.empty {
  text-align: center;
  color: #8b94a6;
  margin-top: 60rpx;
}
